# =============================================================================
# DIFAL / GNRE Generator — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env
#
# No Portainer: adicione estas variáveis em
#   Stack > Environment variables  (não suba o .env para o repositório!)
# =============================================================================


# -----------------------------------------------------------------------------
# BANCO DE DADOS (obrigatório em produção)
# -----------------------------------------------------------------------------
# PostgreSQL — preencha com os dados do seu banco no servidor:
#   host = nome do container Postgres na rede Docker interna
#          (ex: "postgres", "db", ou IP interno como "172.20.0.2")
DATABASE_URL=postgresql://gnre_user:senha_forte@postgres:5432/gnre_db

# SQLite — usado automaticamente quando DATABASE_URL não está definido (dev local)
# DATABASE_URL=sqlite:///./data/gnre.db


# -----------------------------------------------------------------------------
# GNRE WEBSERVICE
# -----------------------------------------------------------------------------
# Ambiente do WebService GNRE:
#   2 = Homologação (testes — padrão)
#   1 = Produção
GNRE_AMBIENTE=2

# Certificado global (opcional — prefer use empresa cadastro via UI)
# Deixe vazio se for usar o certificado cadastrado por empresa na interface.
# Formato: arquivos PEM extraídos do PFX.
CERT_PATH=
KEY_PATH=

# URLs do WebService GNRE (opcionais — sobrescreve os padrões se necessário)
# Padrão produção lote:    https://www.gnre.pe.gov.br/gnreWS/services/GnreLoteRecepcao
# Padrão produção result:  https://www.gnre.pe.gov.br/gnreWS/services/GnreResultadoLote
# Padrão homolog lote:     https://www.testegnre.pe.gov.br:444/gnreHWS/services/GnreLoteRecepcao
# Padrão homolog result:   https://www.testegnre.pe.gov.br:444/gnreHWS/services/GnreResultadoLote
GNRE_WS_URL_PROD=
GNRE_WS_URL_HOMOLOG=
GNRE_WS_URL_PROD_RESULT=
GNRE_WS_URL_HOMOLOG_RESULT=

# Verificar SSL do servidor GNRE (true/false) — use false só para debug
GNRE_SSL_VERIFY=true


# -----------------------------------------------------------------------------
# SP DARE-ICMS (automação Playwright)
# -----------------------------------------------------------------------------
# Código de receita DARE para DIFAL no portal SP
SP_DARE_CODIGO_DIFAL=064-2

# Timeout em segundos para a automação do portal SP
SP_PLAYWRIGHT_TIMEOUT=30


# -----------------------------------------------------------------------------
# SERVIDOR
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
